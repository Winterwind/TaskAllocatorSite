<div class="detail-wrap" style="max-width:680px;">
  <nav class="breadcrumb">
    <a href="/profile">Profile</a>
    <span class="breadcrumb-sep">/</span>
    <span>New Project</span>
  </nav>

  <div style="margin-bottom:24px;">
    <h1 style="font-size:20px;font-weight:700;margin-bottom:4px;">Create a new project</h1>
    <p class="text-muted text-sm">A project is where you track tasks and collaborate with others.</p>
  </div>

  {{#if error}}<div class="auth-error" style="margin-bottom:20px;">{{error}}</div>{{/if}}

  <div class="detail-body">
    <div class="detail-body-content" style="padding:24px;">
      <form action="/project" method="POST">
        <div class="form-group">
          <label class="form-label" for="title">Project Title <span style="color:#e53e3e">*</span></label>
          <input class="form-input" type="text" id="title" name="title"
                 placeholder="e.g. Brand Refresh 2026" required autofocus />
        </div>
        <div class="form-group" style="margin-bottom:24px;">
          <label class="form-label" for="description">Description <span class="text-muted" style="font-weight:400;text-transform:none;letter-spacing:0">(optional)</span></label>
          <textarea class="form-input" id="description" name="description"
                    placeholder="What is this project about?"></textarea>
        </div>
        <hr class="divider" />
        <div style="display:flex;gap:10px;justify-content:flex-end;margin-top:20px;">
          <a href="/profile" class="btn btn-secondary">Cancel</a>
          <button type="submit" class="btn btn-primary">Create Project</button>
        </div>
      </form>
    </div>
  </div>
</div>
